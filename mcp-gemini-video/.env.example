# ─── Gemini Video MCP server ───
# Copy this file to `.env` and fill in your key, OR export these in your shell /
# pass them through the learning project's .mcp.json env block.

# REQUIRED: Google AI Studio API key (https://aistudio.google.com/apikey).
# Without it, the server still boots, but every tool call returns a clear error.
GEMINI_API_KEY=

# OPTIONAL: model used by gemini_ask_video (fast, scoped Q&A). Default: gemini-2.5-flash
GEMINI_ASK_MODEL=gemini-2.5-flash

# OPTIONAL: model used by gemini_digest_lesson (full structured digest). Default: gemini-2.5-pro
GEMINI_DIGEST_MODEL=gemini-2.5-pro

# OPTIONAL: override where lesson folders live.
# Default: <projectRoot>/lessons  (projectRoot = the parent of this folder)
# Each lesson is a subfolder containing one video file (.mp4/.mov/.mkv/.webm).
LESSONS_DIR=
